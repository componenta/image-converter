{
    "name": "componenta/image-converter",
    "description": "Image conversion helpers for Componenta",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-gd": "*",
        "componenta/mimetype-detector": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Image\\": "src/"
        }
    },
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Image\\ConfigProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
